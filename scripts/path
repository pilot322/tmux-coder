#!/usr/bin/env bash
set -euo pipefail

root_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  echo "usage: ./dev path client|daemon" >&2
}

if [[ $# -ne 1 ]]; then
  usage
  exit 2
fi

case "$1" in
  client)
    printf '%s\n' "$root_dir/bin/tmux-coder"
    ;;
  daemon)
    printf '%s\n' "$root_dir/bin/tmux-coderd"
    ;;
  *)
    usage
    exit 2
    ;;
esac
