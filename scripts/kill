#!/usr/bin/env bash
set -euo pipefail

root_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
tmux_server_env="TMUX_CODER_TMUX_SERVER"
default_tmux_server="tmux-coder"

usage() {
  echo "usage: ./dev kill [-a]" >&2
}

if [[ $# -gt 1 ]]; then
  usage
  exit 2
fi

all=0
case "${1:-}" in
  "")
    ;;
  -a)
    all=1
    ;;
  *)
    usage
    exit 2
    ;;
esac

local_daemon="$root_dir/bin/tmux-coderd"
if [[ $all -eq 0 && ! -e "$local_daemon" ]]; then
  echo "local daemon binary not found: $local_daemon" >&2
  exit 1
fi

local_daemon_real=""
if [[ $all -eq 0 ]]; then
  local_daemon_real="$(readlink -f "$local_daemon")"
fi

pids=()
tmux_servers=()

# env_from_proc prints a variable from a process's launch-time environment, or
# nothing if it is unset. /proc/<pid>/environ only reflects the environment that
# existed at exec, so it misses any var the daemon sets later (loadEnvFile in
# cmd/tmux-coderd reads the worktree .env via os.Setenv after start-up).
env_from_proc() {
  local pid="$1"
  local name="$2"
  local entry

  [[ -r "/proc/$pid/environ" ]] || return 0
  while IFS= read -r -d '' entry; do
    if [[ "${entry%%=*}" == "$name" ]]; then
      printf '%s\n' "${entry#*=}"
      return 0
    fi
  done < "/proc/$pid/environ"
}

# env_from_file prints a variable from a .env file using the same parsing rules
# as loadEnvFile in cmd/tmux-coderd/main.go, or nothing if absent. This is the
# label source a worktree daemon actually uses but never exposes in its
# environment.
env_from_file() {
  local file="$1"
  local name="$2"
  local line key value

  [[ -r "$file" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" || "$line" == \#* ]] && continue
    [[ "$line" == *=* ]] || continue
    key="${line%%=*}"
    key="${key#"${key%%[![:space:]]*}"}"
    key="${key%"${key##*[![:space:]]}"}"
    [[ "$key" == "$name" ]] || continue
    value="${line#*=}"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    value="${value#[\"\']}"
    value="${value%[\"\']}"
    printf '%s\n' "$value"
    return 0
  done < "$file"
}

# tmux_server_for_pid resolves the tmux server label a daemon is using, mirroring
# the daemon's own precedence: an env var exported before launch wins (it is the
# only label visible in /proc/<pid>/environ, and loadEnvFile skips already-set
# keys), otherwise the worktree .env two directories up from <worktree>/bin/
# tmux-coderd. With neither, a dev build still has its label baked in by
# scripts/build via -ldflags, so reconstruct it the same way scripts/build does
# from the worktree path; the scripts/build guard keeps this from ever firing on
# the installed (prod) daemon, which falls through to the shipped default.
tmux_server_for_pid() {
  local pid="$1"
  local exe="$2"
  local value root

  value="$(env_from_proc "$pid" "$tmux_server_env")"
  if [[ -z "$value" && -n "$exe" ]]; then
    root="$(dirname "$(dirname "$exe")")"
    value="$(env_from_file "$root/.env" "$tmux_server_env")"
    if [[ -z "$value" && "$exe" == */bin/tmux-coderd && -f "$root/scripts/build" ]]; then
      value="tmux-coder-$(basename "$root")"
    fi
  fi
  if [[ -z "$value" ]]; then
    value="$default_tmux_server"
  fi
  printf '%s\n' "$value"
}

add_tmux_server() {
  local server="$1"
  local existing
  for existing in "${tmux_servers[@]}"; do
    if [[ "$existing" == "$server" ]]; then
      return
    fi
  done
  tmux_servers+=("$server")
}

for proc in /proc/[0-9]*; do
  pid="${proc##*/}"
  comm=""
  if [[ -r "$proc/comm" ]]; then
    IFS= read -r comm < "$proc/comm" || true
  fi
  if [[ "$comm" != "tmux-coderd" ]]; then
    continue
  fi

  exe="$(readlink "$proc/exe" 2>/dev/null || true)"
  exe="${exe% (deleted)}"
  if [[ -z "$exe" ]]; then
    continue
  fi

  if [[ $all -eq 1 ]]; then
    if [[ "$exe" == */bin/tmux-coderd ]]; then
      pids+=("$pid")
      add_tmux_server "$(tmux_server_for_pid "$pid" "$exe")"
    fi
  elif [[ "$(readlink -f "$exe")" == "$local_daemon_real" ]]; then
    pids+=("$pid")
    add_tmux_server "$(tmux_server_for_pid "$pid" "$exe")"
  fi
done

if [[ ${#pids[@]} -eq 0 ]]; then
  echo "no matching tmux-coderd processes found"
  exit 0
fi

kill "${pids[@]}"
printf 'killed tmux-coderd pid %s\n' "${pids[@]}"

for server in "${tmux_servers[@]}"; do
  if tmux -L "$server" kill-server 2>/dev/null; then
    printf 'killed tmux server %s\n' "$server"
  else
    printf 'no tmux server %s found\n' "$server"
  fi
done
