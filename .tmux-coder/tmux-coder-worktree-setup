#!/usr/bin/env bash
set -euo pipefail

root_dir="${TMUX_CODER_WORKTREE_ROOT:?}"
cd "$root_dir"

worktree_name="$(basename "$root_dir")"
path_hash="$(printf '%s' "$root_dir" | cksum | cut -d' ' -f1)"
dev_port=$(( 64357 + (path_hash % 200) + 1 ))
dev_label="tmux-coder-${worktree_name}"

cat > .env <<EOF
# Generated by tmux-coder worktree hook.
# Subsequent ./dev build commands in this worktree bake these values into bin/.
TMUX_CODERD_PORT=${dev_port}
TMUX_CODER_TMUX_SERVER=${dev_label}
TMUX_CODER_BIN=${root_dir}/bin
EOF
